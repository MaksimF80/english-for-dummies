{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Caveat|Figtree|Newsreader))/i]",
        "message": "Font not provided by the design system. Available: Caveat, Figtree, Newsreader."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:coral|amber|teal|raspberry|neutral|success)$/]",
        "message": "<Badge> tone must be one of 'coral' | 'amber' | 'teal' | 'raspberry' | 'neutral' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlogCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|excerpt|category|date|readTime|coverId|coverSrc|accent|href|key|ref|className|style|children)$/]",
        "message": "<BlogCard> doesn't accept that prop. Declared props: title, excerpt, category, date, readTime, coverId, coverSrc, accent, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlogCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:coral|amber|teal|raspberry)$/]",
        "message": "<BlogCard> accent must be one of 'coral' | 'amber' | 'teal' | 'raspberry'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|full|disabled|as|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, full, disabled, as, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|teal|ghost|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'teal' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|padding|tone|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, padding, tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:card|raised)$/]",
        "message": "<Card> tone must be one of 'card' | 'raised'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CourseCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|level|format|duration|price|priceUnit|ctaLabel|accent|href|key|ref|className|style|children)$/]",
        "message": "<CourseCard> doesn't accept that prop. Declared props: title, description, level, format, duration, price, priceUnit, ctaLabel, accent, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='CourseCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:coral|amber|teal|raspberry)$/]",
        "message": "<CourseCard> accent must be one of 'coral' | 'amber' | 'teal' | 'raspberry'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|showText|onDark|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: size, showText, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Logo> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|active|children|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: href, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|label|href|tone|size|key|ref|className|style|children)$/]",
        "message": "<SocialIcon> doesn't accept that prop. Declared props: name, label, href, tone, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cream|coral|outline)$/]",
        "message": "<SocialIcon> tone must be one of 'cream' | 'coral' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeacherSocial'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|href|label|key|ref|className|style|children)$/]",
        "message": "<TeacherSocial> doesn't accept that prop. Declared props: name, href, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
